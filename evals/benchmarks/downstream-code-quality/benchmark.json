{
  "schemaVersion": 1,
  "id": "downstream-code-quality",
  "claim": "Non-promotional directional evidence about skill-driven downstream Codex code quality for one synthetic Rust feature case.",
  "promotionEligible": false,
  "provider": {
    "id": "openai:codex-sdk",
    "model": "gpt-5.6-terra",
    "reasoningEffort": "medium",
    "sandboxMode": "workspace-write",
    "approvalPolicy": "never",
    "networkAccess": false,
    "authentication": "dedicated-api-key-only"
  },
  "sampleCount": 3,
  "conditions": [
    {
      "id": "no-marketplace-skills",
