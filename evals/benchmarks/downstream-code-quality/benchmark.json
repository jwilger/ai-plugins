  "diagnosticGates": {
    "expectedExecutionTurns": 9,
    "completeRuns": 9,
    "providerErrors": 0,
    "operationalErrors": 0,
    "provenanceErrors": 0,
    "safetyFailures": 0,
    "candidateFailuresAreMeasurementOutcomes": true
  }
