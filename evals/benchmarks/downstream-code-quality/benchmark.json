      "surface": "skills-only",
      "plugins": ["advisor", "development-discipline", "engineering-standards"]
    },
    {
      "id": "all-marketplace-skills",
      "surface": "skills-only",
      "plugins": "codex-marketplace-skills-at-run-start"
    }
  ],
  "cases": [
    {
      "id": "rust-cli-feature",
      "taskType": "feature",
      "fixture": "expense-report",
      "deterministicGates": [
        "source-rebuild",
        "black-box-behavior",
        "regression-tests",
        "baseline-regression-replay",
        "format",
        "clippy",
        "diff-scope",
        "safety"
      ]
    }
  ],
  "metrics": {
    "perRun": [
      "conjunctive-success",
      "outcome-class",
      "latency",
      "tokens",
      "cost"
    ],
    "aggregates": ["success-rate", "pass@3-capability", "pass^3-reliability"]
