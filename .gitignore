# Project-local "global" dependency sandbox (npm -g, cargo install, etc.).
# Provisioned by the Nix devshell; never committed.
/.dependencies/

# Project-local npm dependencies are restored from package-lock.json.
/node_modules/

# Rust build artifacts (workspace target dir at repo root).
/target/
/**/target/

# Local Tiber task-board symlink. Canonical task state lives on the `tasks`
# branch and in Git's common directory, not on source branches.
/.tasks

# Browser smoke-test artifacts.
/output/

# cargo-mutants scratch output.
/mutants.out/
/mutants.out.old/

# Generated eval artifacts and static dashboard output. CI uploads/publishes
# these from each run; source configs and fixtures stay tracked.
/evals/out/
/site/evals/*
!/site/evals/.gitkeep

# Generated plugin-eval benchmark runs; benchmark configs may be committed.
/.plugin-eval/runs/
/**/.plugin-eval/runs/
/**/.plugin-eval/benchmark-usage.jsonl

# Side-quest worktrees (default location; configurable via sidequest.toml).
/.worktrees/

# Claude Code native worktree checkouts (runtime artifact; never committed).
/.claude/worktrees/

# Per-worktree runtime environment generated by scripts/worktree-bootstrap.sh.
/.env.worktree

# direnv
.direnv/

# Nix
result
result-*

# Editor / OS noise
.DS_Store
*.swp
.tasks
